+/**
+ * Utility to detect if the application is running in "Demo Mode" (mock data enabled).
+ * 
+ * Demo Mode is active if:
+ * 1. Current hostname is a known demo/mock subdomain.
+ * 2. Current environment is development (localhost).
+ * 3. Vercel deployment branch contains "demo".
+ */
+export const isDemoMode = (): boolean => {
+  if (typeof window === 'undefined') return false;
+
+  const hostname = window.location.hostname;
+  
+  // Known demo subdomains
+  const demoDomains = [
+    'demo.livix.es',
+    'mock.livix.es',
+    'admin-demo.livix.es',
+  ];
+
+  if (demoDomains.includes(hostname)) return true;
+
+  // Local development
+  if (hostname === 'localhost' || hostname === '127.0.0.1') return true;
+
+  // Vercel preview deployments for branch 'demo'
+  // Pattern: livix-main-git-demo-username.vercel.app
+  if (hostname.includes('-git-demo-') || hostname.includes('.vercel.app') && hostname.startsWith('demo-')) {
+    return true;
+  }
+
+  // Check URL params for manual override (useful for specific tests)
+  const urlParams = new URLSearchParams(window.location.search);
+  if (urlParams.get('demo') === 'true') return true;
+
+  return false;
+};
+
+export default isDemoMode;
