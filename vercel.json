{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npm run build:sitemap && npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "trailingSlash": false,
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(habitaciones|pisos|residencias|colegios-mayores|campus|blog|erasmus)/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, s-maxage=86400, stale-while-revalidate=3600"
                }
            ]
        },
        {
            "source": "/(about|pricing|how-it-works|landlords|residences|roommates|publicar-habitacion|support|club|explore)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, s-maxage=86400, stale-while-revalidate=3600"
                }
            ]
        },
        {
            "source": "/((?!assets/|habitaciones/|pisos/|residencias/|colegios-mayores/|campus/|blog|erasmus|about|pricing|how-it-works|landlords|residences|roommates|publicar-habitacion|support|club|explore).*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/(ll|admin|student|onboarding|settings|profile|bookings|messages|favorites|login|signup)(.*)",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, nofollow"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "SAMEORIGIN"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://maps.googleapis.com https://maps.gstatic.com https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net https://analytics.tiktok.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https: http:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://maps.googleapis.com https://api.stripe.com https://www.google-analytics.com https://www.googletagmanager.com https://region1.google-analytics.com https://www.facebook.com https://connect.facebook.net https://analytics.tiktok.com; frame-src https://js.stripe.com https://hooks.stripe.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=31536000; includeSubDomains"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=(self), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
                }
            ]
        }
    ],
    "redirects": [
        { "source": "/blog/1", "destination": "/blog/guia-estudiantes-zaragoza", "statusCode": 301 },
        { "source": "/blog/2", "destination": "/blog/mejores-barrios-estudiantes-zaragoza", "statusCode": 301 },
        { "source": "/blog/3", "destination": "/blog/residencia-universitaria-o-piso-compartido", "statusCode": 301 },
        { "source": "/blog/4", "destination": "/blog/coste-vida-estudiantes-zaragoza", "statusCode": 301 },
        { "source": "/blog/5", "destination": "/blog/evitar-estafas-alquiler-estudiantes", "statusCode": 301 },
        { "source": "/blog/6", "destination": "/blog/alquilar-habitacion-zaragoza-paso-a-paso", "statusCode": 301 },
        { "source": "/blog/7", "destination": "/blog/residencia-vs-piso-compartido-zaragoza", "statusCode": 301 },
        { "source": "/blog/8", "destination": "/blog/guia-erasmus-zaragoza", "statusCode": 301 },
        { "source": "/blog/9", "destination": "/blog/precio-habitacion-zaragoza-por-barrios", "statusCode": 301 },
        { "source": "/blog/10", "destination": "/blog/mejores-residencias-universitarias-zaragoza", "statusCode": 301 },
        { "source": "/blog/11", "destination": "/blog/colegio-mayor-pedro-cerbuna-zaragoza", "statusCode": 301 },
        { "source": "/blog/12", "destination": "/blog/vivir-actur-estudiante-zaragoza", "statusCode": 301 },
        { "source": "/blog/13", "destination": "/blog/contrato-alquiler-estudiantes-clausulas", "statusCode": 301 },
        { "source": "/blog/14", "destination": "/blog/becas-ayudas-alojamiento-aragon", "statusCode": 301 },
        { "source": "/blog/15", "destination": "/blog/beca-mec-2026-2027-requisitos-cuantias", "statusCode": 301 }
    ],
    "rewrites": [
        {
            "source": "/((?!llms\\.txt|robots\\.txt|sitemap\\.xml|image-sitemap\\.xml|manifest\\.json|favicon\\.png|logo\\.png|og-livix\\.jpg|a02d1f3919e649d59bfda0dd9ec318b1\\.txt).*)",
            "destination": "/index.html"
        }
    ]
}
